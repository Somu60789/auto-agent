# Single config for all services. Copy to .env and fill in.
# Load before `npm start`:  export $(grep -v '^#' .env | xargs)

# --- Secrets ---
# GitHub Personal Access Token with repo + workflow read scope (required)
GITHUB_TOKEN=
# Optional Codecov API token (for private-repo coverage; public repos work without it)
CODECOV_TOKEN=
# Co-Worker agent auth for the spawned `claude` CLI (needed on a deployed host
# with no interactive `~/.claude` login). Set ONE of these:
#   ANTHROPIC_API_KEY        — API billing
#   CLAUDE_CODE_OAUTH_TOKEN  — subscription token from `claude setup-token`
# API key takes precedence if both are set.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# --- Paths ---
# Absolute path to the local TML_Repos directory
TML_REPOS_PATH=/home/somasekhar/Desktop/TML_Repos
# Absolute path to the local ep-pipelines clone (defaults to TML_REPOS_PATH/ep-pipelines)
EP_PIPELINES_PATH=
# Where the Co-Worker agent clones/edits repos (defaults to <parent of TML_REPOS_PATH>/ALL_Repos)
ALL_REPOS_PATH=
# Where the agent persists its session index (defaults to ALL_REPOS_PATH/.co-worker)
AGENT_STATE_DIR=

# --- Settings ---
# Path/name of the claude CLI binary
CLAUDE_BIN=claude
# Default GitHub org/user used to clone a repo typed by bare name in the agent
GITHUB_OWNER=tmlconnected
# Backend port
PORT=4000
# Cache lifetime for enriched repo data, in seconds
CACHE_TTL_SECONDS=300
